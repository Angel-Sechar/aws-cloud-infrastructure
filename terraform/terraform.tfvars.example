aws_region = "sa-east-1"
owner      = "your-name"

vpc_cidr              = "10.0.0.0/16"
public_subnet_a_cidr  = "10.0.1.0/24"
public_subnet_b_cidr  = "10.0.2.0/24"
private_subnet_a_cidr = "10.0.3.0/24"
private_subnet_b_cidr = "10.0.4.0/24"
availability_zone_a   = "sa-east-1a"
availability_zone_b   = "sa-east-1c"

instance_type = "t2.micro"

asg_min_size         = 1
asg_max_size         = 3
asg_desired_capacity = 1

lambda_runtime     = "python3.14"
lambda_timeout     = 3
lambda_memory_size = 128

cpu_scale_out_threshold      = 60
cpu_scale_in_threshold       = 30
scale_out_evaluation_periods = 2
scale_in_evaluation_periods  = 3
alarm_period                 = 120

sns_email = "your@email.com"
